#!/bin/bash

set -e

# cco - Claude Container (or Claude Condom if you're so inclined)
# A thin protective layer for Claude Code
# Supports multiple sandboxing backends: native (bubblewrap/seatbelt) or Docker

# Sandbox backend preference
SANDBOX_BACKEND="" # auto, native, docker

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Single mechanism for all user-facing messages: colored icon + text to stderr
msg() {
	local color="$1" icon="$2" text="$3"
	echo -e "${color}${icon}${NC} ${text}" >&2
}

log() { msg "$GREEN" "▶" "$1"; }
warn() { msg "$YELLOW" "⚠" "$1"; }
error() { msg "$RED" "✗" "$1"; }

# Determine if we're running from installation or development
if [[ -f "./Dockerfile" && -f "./cco" ]]; then
	# Current directory is a cco development environment
	CCO_INSTALLATION_DIR="$PWD"
	log "Detected cco development environment, building locally"
elif [[ -d "$HOME/.local/share/cco/.git" && "$(basename "$(dirname "$0")")" != "cco" ]]; then
	# Running from symlink, use installation directory
	CCO_INSTALLATION_DIR="$HOME/.local/share/cco"
else
	# Running from development directory
	CCO_INSTALLATION_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
fi

IMAGE_NAME="cco:latest"
# Generate unique container name to allow concurrent sessions
# Sanitize directory name for Docker container naming (only alphanumeric, underscore, dash, dot)
sanitized_dir=$(basename "$PWD" | tr -c '[:alnum:]._-' '_')
CONTAINER_NAME="cco-${sanitized_dir}-$(date +%s)-$$"

# Detect available sandbox backends
detect_sandbox_backend() {
	local force_backend="$1"

	if [[ -n "$force_backend" ]]; then
		case "$force_backend" in
		native | docker)
			SANDBOX_BACKEND="$force_backend"
			return
			;;
		auto | "")
			# Continue with auto-detection
			;;
		*)
			error "Invalid sandbox backend: $force_backend"
			error "Valid options: auto, native, docker"
			exit 1
			;;
		esac
	fi

	# Auto-detect best available backend
	local os
	os="$(uname -s)"

	if [[ "$os" == "Darwin" ]]; then
		# macOS: Check for sandbox-exec (Seatbelt)
		if command -v sandbox-exec &>/dev/null; then
			SANDBOX_BACKEND="native"
			log "Using native sandbox (Seatbelt)"
		elif command -v docker &>/dev/null && docker info &>/dev/null 2>&1; then
			SANDBOX_BACKEND="docker"
			log "Using Docker sandbox (Seatbelt not available)"
		else
			error "No sandbox backend available. Install Docker or ensure sandbox-exec is available."
			exit 1
		fi
	elif [[ "$os" == "Linux" ]]; then
		# Linux: Check for bubblewrap
		if command -v bwrap &>/dev/null; then
			SANDBOX_BACKEND="native"
			log "Using native sandbox (bubblewrap)"
		elif command -v docker &>/dev/null && docker info &>/dev/null 2>&1; then
			SANDBOX_BACKEND="docker"
			log "Using Docker sandbox (bubblewrap not available)"
		else
			error "No sandbox backend available. Install bubblewrap or Docker."
			exit 1
		fi
	else
		error "Unsupported OS: $os"
		exit 1
	fi
}

# Determine Claude command to use (configurable via CLI flag or environment variable)
get_claude_command() {
	if [[ -n "$claude_command_flag" ]]; then
		echo "$claude_command_flag"
	elif [[ -n "$CCO_CLAUDE_COMMAND" ]]; then
		echo "$CCO_CLAUDE_COMMAND"
	else
		echo "claude"
	fi
}

# Determine command to run (configurable via CLI flag or environment variable)
# This allows running arbitrary commands instead of Claude
get_command() {
	if [[ -n "$command_flag" ]]; then
		echo "$command_flag"
	elif [[ -n "$CCO_COMMAND" ]]; then
		echo "$CCO_COMMAND"
	else
		get_claude_command
	fi
}

# Load agent-specific behavior/policies from dedicated modules.
if [[ -f "$CCO_INSTALLATION_DIR/lib/agents.sh" ]]; then
	# shellcheck source=/dev/null
	source "$CCO_INSTALLATION_DIR/lib/agents.sh"
else
	error "Missing required module: $CCO_INSTALLATION_DIR/lib/agents.sh"
	exit 1
fi

path_in_array() {
	local needle="$1"
	shift
	for element in "$@"; do
		if [[ "$element" == "$needle" ]]; then
			return 0
		fi
	done
	return 1
}

remove_path_from_array() {
	local target="$1"
	shift
	local new_arr=()

	for element in "$@"; do
		if [[ "$element" != "$target" ]]; then
			new_arr+=("$element")
		fi
	done

	# Use newline delimiter (not space) so paths with spaces survive round-trip
	printf '%s\n' "${new_arr[@]}"
}

# Resolve a path to an absolute form, tolerating files or directories that may not yet exist.
resolve_path() {
	local input="$1"
	local expanded="$input"
	if [[ "$expanded" == ~* ]]; then
		expanded="${expanded/#\~/$HOME}"
	fi

	if [[ -d "$expanded" ]]; then
		(cd "$expanded" && pwd)
		return
	fi

	local dir base
	dir=$(dirname "$expanded")
	base=$(basename "$expanded")
	if [[ "$dir" == ~* ]]; then
		dir="${dir/#\~/$HOME}"
	fi
	if [[ -d "$dir" ]]; then
		(cd "$dir" && printf '%s/%s\n' "$(pwd)" "$base")
	else
		# Fall back to combining with current working directory.
		if [[ "$dir" == "." ]]; then
			printf '%s/%s\n' "$PWD" "$base"
		else
			printf '%s/%s\n' "$dir" "$base"
		fi
	fi
}

resolve_existing_dir() {
	local input="$1"
	local expanded="$input"
	if [[ "$expanded" == ~* ]]; then
		expanded="${expanded/#\~/$HOME}"
	fi
	if [[ ! -d "$expanded" ]]; then
		return 1
	fi
	(cd "$expanded" && pwd -P)
}

add_rw_path() {
	local path="$1"
	if [[ ! -d "$path" ]]; then
		warn "Directory does not exist: $path"
		return 1
	fi
	IFS=$'\n' read -r -d '' -a additional_ro_paths < <(remove_path_from_array "$path" "${additional_ro_paths[@]}") || true
	IFS=$'\n' read -r -d '' -a deny_paths < <(remove_path_from_array "$path" "${deny_paths[@]}") || true
	if ! path_in_array "$path" "${additional_dirs[@]}"; then
		additional_dirs+=("$path")
	fi
	return 0
}

add_ro_path() {
	local path="$1"
	if [[ ! -e "$path" ]]; then
		warn "Path does not exist for read-only share: $path"
		return 1
	fi
	IFS=$'\n' read -r -d '' -a additional_dirs < <(remove_path_from_array "$path" "${additional_dirs[@]}") || true
	IFS=$'\n' read -r -d '' -a deny_paths < <(remove_path_from_array "$path" "${deny_paths[@]}") || true
	if ! path_in_array "$path" "${additional_ro_paths[@]}"; then
		additional_ro_paths+=("$path")
	fi
	return 0
}

add_deny_path() {
	local path="$1"
	if [[ ! -e "$path" ]]; then
		warn "Path does not exist for deny rule: $path"
		return 1
	fi
	IFS=$'\n' read -r -d '' -a additional_dirs < <(remove_path_from_array "$path" "${additional_dirs[@]}") || true
	IFS=$'\n' read -r -d '' -a additional_ro_paths < <(remove_path_from_array "$path" "${additional_ro_paths[@]}") || true
	if ! path_in_array "$path" "${deny_paths[@]}"; then
		deny_paths+=("$path")
	fi
}

handle_add_dir_entry() {
	local raw="$1"
	local mode="rw"
	if [[ "$raw" == *":ro" ]]; then
		raw="${raw%:ro}"
		mode="ro"
	elif [[ "$raw" == *":rw" ]]; then
		raw="${raw%:rw}"
	fi

	local resolved
	resolved=$(resolve_path "$raw")

	if [[ -z "$resolved" ]]; then
		return
	fi

	case "$mode" in
	rw)
		add_rw_path "$resolved"
		;;
	ro)
		add_ro_path "$resolved"
		;;
	*)
		error "Unknown mode for --add-dir entry: $mode"
		exit 1
		;;
	esac
}

# Check if Docker is available (only when using Docker backend)
check_docker_dependencies() {
	# Check for Docker
	if ! command -v docker &>/dev/null; then
		error "Docker is not installed or not in PATH"
		error "Please install Docker: https://docs.docker.com/get-docker/"
		exit 1
	fi

	if ! docker info &>/dev/null; then
		error "Docker daemon is not running"
		error "Please start Docker and try again"
		exit 1
	fi
}

# Check general dependencies
check_dependencies() {
	# Check for git (required for version detection and updates)
	if ! command -v git &>/dev/null; then
		error "Git is not installed or not in PATH"
		error "Please install git: https://git-scm.com/downloads"
		exit 1
	fi
}

# Determine Claude Code config directory following priority order:
# 1. CLAUDE_CONFIG_DIR env var (if set)
# 2. XDG_CONFIG_HOME/claude or ~/.config/claude (new default since v1.0.30)
# 3. ~/.claude (legacy fallback)
get_claude_config_dir() {
	if [[ -n "$CLAUDE_CONFIG_DIR" ]]; then
		echo "$CLAUDE_CONFIG_DIR"
	elif [[ -n "$XDG_CONFIG_HOME" ]]; then
		echo "$XDG_CONFIG_HOME/claude"
	elif [[ -d "$HOME/.config" ]]; then
		echo "$HOME/.config/claude"
	else
		echo "$HOME/.claude"
	fi
}

# Find where Claude Code actually stores its configuration
find_claude_config_dir() {
	local primary_dir
	primary_dir=$(get_claude_config_dir)
	local legacy_dir="$HOME/.claude"

	# Check primary location first
	if [[ -d "$primary_dir" ]] && [[ -f "$primary_dir/.credentials.json" || -n "$(command -v security)" ]]; then
		echo "$primary_dir"
		return
	fi

	# Fall back to legacy location
	if [[ -d "$legacy_dir" ]] && [[ -f "$legacy_dir/.credentials.json" || -n "$(command -v security)" ]]; then
		echo "$legacy_dir"
		return
	fi

	# Return primary location for error reporting
	echo "$primary_dir"
}

# Claude authentication is optional. cco may be used with external API keys or
# alternative commands, so startup must not require local Claude credentials.

# Sync updated credentials back to host system
sync_credentials_back() {
	local temp_creds_dir="$1"
	local original_content="$2"
	local host_creds_file="$3"
	local startup_system_content="$4"
	local temp_creds_file="$temp_creds_dir/.credentials.json"

	# Check if credentials file exists and was potentially updated
	if [[ ! -f "$temp_creds_file" ]]; then
		return 0 # No credentials file to sync
	fi

	# Check if credentials content changed
	local current_content
	current_content=$(cat "$temp_creds_file")

	# If content unchanged, no sync needed
	if [[ "$current_content" = "$original_content" ]]; then
		return 0
	fi

	log "Detected updated credentials, syncing back to host system..."

	# Safety check: Verify system credentials haven't changed during our session
	local current_system_content=""
	if command -v security &>/dev/null; then
		# macOS: Check current Keychain content
		current_system_content=$(security find-generic-password -s "Claude Code-credentials" -a "$USER" -w 2>/dev/null || echo "")
	elif [[ -n "$host_creds_file" && -f "$host_creds_file" ]]; then
		# Linux: Check current file content
		current_system_content=$(cat "$host_creds_file")
	fi

	# Abort if system credentials changed during our session
	if [[ -n "$startup_system_content" && -n "$current_system_content" && "$startup_system_content" != "$current_system_content" ]]; then
		warn "SAFETY ABORT: System credentials were modified during session by another process"
		warn "This could be Claude CLI, another cco instance, or manual changes"
		warn "Skipping sync-back to prevent credential conflicts"
		warn "Your container's updated credentials are preserved in: $temp_creds_file"
		warn "To manually sync: ./cco restore-creds '$temp_creds_file'"
		return 1
	fi

	# Create backup timestamp
	local backup_timestamp
	backup_timestamp=$(date +"%Y%m%d_%H%M%S")

	# Sync back based on platform
	if command -v security &>/dev/null; then
		# macOS: Backup and update Keychain
		log "Creating backup of original Keychain credentials..."
		local original_creds
		original_creds=$(security find-generic-password -s "Claude Code-credentials" -a "$USER" -w 2>/dev/null || echo "")
		if [[ -n "$original_creds" ]]; then
			# Save backup to temp location
			echo "$original_creds" >"$temp_creds_dir/.credentials.backup.$backup_timestamp.json"
			log "Backup saved to: $temp_creds_dir/.credentials.backup.$backup_timestamp.json"
		fi

		# Update Keychain with new credentials
		local creds_content
		creds_content=$(cat "$temp_creds_file")
		if security add-generic-password -U -s "Claude Code-credentials" -a "$USER" -w "$creds_content" >/dev/null 2>&1; then
			log "Successfully updated credentials in macOS Keychain"
		else
			warn "Failed to update macOS Keychain, credentials may be out of sync"
			if [[ -f "$temp_creds_dir/.credentials.backup.$backup_timestamp.json" ]]; then
				warn "Original credentials backup available at: $temp_creds_dir/.credentials.backup.$backup_timestamp.json"
				warn "To restore: security add-generic-password -U -s 'Claude Code-credentials' -a '$USER' -w \"\$(cat '$temp_creds_dir/.credentials.backup.$backup_timestamp.json')\""
			fi
		fi
	elif [[ -n "$host_creds_file" && -f "$host_creds_file" ]]; then
		# Linux: Backup and update credentials file
		local backup_file="${host_creds_file}.backup.$backup_timestamp"
		log "Creating backup of original credentials file..."
		if cp "$host_creds_file" "$backup_file"; then
			log "Backup saved to: $backup_file"

			# Update credentials file with new content
			if cp "$temp_creds_file" "$host_creds_file"; then
				log "Successfully updated credentials file: $host_creds_file"
			else
				warn "Failed to update credentials file: $host_creds_file"
				warn "Restoring from backup..."
				if cp "$backup_file" "$host_creds_file"; then
					warn "Successfully restored original credentials from backup"
				else
					warn "Failed to restore backup! Original credentials backup available at: $backup_file"
				fi
			fi
		else
			warn "Failed to create backup, skipping credentials update for safety"
		fi
	fi
}

# Check if we should use pre-built image
should_use_prebuilt_image() {
	# Don't use pre-built if explicitly rebuilding
	if [[ "$rebuild_image" = true ]]; then
		return 1
	fi

	# Don't use pre-built if custom packages specified
	if [[ ${#custom_packages[@]} -gt 0 ]]; then
		return 1
	fi

	# Don't use pre-built if Dockerfile has been modified locally
	if [[ -d "$CCO_INSTALLATION_DIR/.git" ]]; then
		local dockerfile_status
		dockerfile_status=$(cd "$CCO_INSTALLATION_DIR" && git status --porcelain Dockerfile 2>/dev/null)
		if [[ -n "$dockerfile_status" ]]; then
			return 1
		fi
	fi

	return 0
}

# Get the appropriate image tag for current version
get_prebuilt_image_tag() {
	if [[ -d "$CCO_INSTALLATION_DIR/.git" ]]; then
		local commit_sha
		commit_sha=$(cd "$CCO_INSTALLATION_DIR" && git rev-parse --short HEAD 2>/dev/null)
		echo "ghcr.io/ragibcs/cco:${commit_sha}"
	else
		echo "ghcr.io/ragibcs/cco:latest"
	fi
}

# Try to pull pre-built image
pull_prebuilt_image() {
	local image_tag
	image_tag=$(get_prebuilt_image_tag)

	log "Attempting to pull pre-built image: $image_tag"

	# First check if the image exists in the registry
	log "Checking if pre-built image is available..."
	if ! docker manifest inspect "$image_tag" >/dev/null 2>&1; then
		warn "Pre-built image not found in registry, building locally..."
		return 1
	fi

	log "Pre-built image found, downloading..."
	# Pull without timeout - let it take as long as needed
	if docker pull "$image_tag" 2>&1; then
		# Tag as local image name for consistency
		docker tag "$image_tag" "$IMAGE_NAME" >/dev/null 2>&1
		log "Successfully pulled pre-built image"
		return 0
	else
		warn "Failed to pull pre-built image, building locally..."
		return 1
	fi
}

# Build Docker image
build_image() {
	local original_dir="$PWD"

	log "Building cco Docker image..."

	# Build from the directory containing the cco script
	cd "$CCO_INSTALLATION_DIR" || {
		error "cco installation not found at $CCO_INSTALLATION_DIR"
		error "Run: curl -fsSL https://raw.githubusercontent.com/ragibcs/cco/master/install.sh | bash"
		exit 1
	}

	local build_args=()

	# Add custom packages if specified
	if [[ ${#custom_packages[@]} -gt 0 ]]; then
		local packages_list
		packages_list=$(
			IFS=' '
			echo "${custom_packages[*]}"
		)
		log "Installing additional packages: $packages_list"
		build_args+=(--build-arg CUSTOM_PACKAGES="$packages_list")
	fi

	# Check for custom Dockerfile in XDG config directory
	local custom_dockerfile="${XDG_CONFIG_HOME:-$HOME/.config}/cco/Dockerfile"
	local dockerfile_arg=""

	if [[ -f "$custom_dockerfile" ]]; then
		log "Using custom Dockerfile: $custom_dockerfile"
		dockerfile_arg=("-f" "$custom_dockerfile")
	else
		log "Using default Dockerfile"
		dockerfile_arg=("-f" "Dockerfile")
	fi

	# Add cache-busting argument to force Claude Code reinstallation on --rebuild
	build_args+=(--build-arg CACHE_BUST="$(date +%s)")

	# Use cache-from if we have a local pre-built image available
	local prebuilt_image_tag
	prebuilt_image_tag=$(get_prebuilt_image_tag)
	if docker image inspect "$prebuilt_image_tag" &>/dev/null; then
		log "Using local pre-built image for build cache: $prebuilt_image_tag"
		build_args+=(--cache-from "$prebuilt_image_tag")
	fi

	docker build -t "$IMAGE_NAME" "${build_args[@]}" "${dockerfile_arg[@]}" .
	cd "$original_dir"
	log "Image built successfully"
}

# Update cco installation
update_cco() {
	if [[ ! -d "$CCO_INSTALLATION_DIR/.git" ]]; then
		error "cco installation not found at $CCO_INSTALLATION_DIR"
		error "Run: curl -fsSL https://raw.githubusercontent.com/ragibcs/cco/master/install.sh | bash"
		exit 1
	fi

	local original_dir="$PWD"
	cd "$CCO_INSTALLATION_DIR"

	log "Updating cco installation..."

	# Check for local modifications
	if ! git diff --quiet HEAD 2>/dev/null; then
		warn "WARNING: Your cco installation has local modifications."
		warn "Most users should reset to the latest version (this is safe)."
		warn "Only say 'no' if you've customized cco yourself."
		echo
		read -p "Reset to latest version and lose local changes? [Y/n] " -n 1 -r
		echo
		if [[ $REPLY =~ ^[Nn]$ ]]; then
			warn "Skipping update to preserve local changes"
			cd "$original_dir"
			return 1
		fi
		log "Resetting to latest version..."
		git reset --hard origin/master
	fi

	git fetch origin
	git pull origin master
	local new_version
	new_version=$(git rev-parse --short HEAD)
	log "Updated to $new_version"

	cd "$original_dir"
	log "Update complete!"
}

# Show version information
show_version() {
	if [[ -d "$CCO_INSTALLATION_DIR/.git" ]]; then
		local version
		version=$(cd "$CCO_INSTALLATION_DIR" && git rev-parse --short HEAD 2>/dev/null || echo "unknown")
		local install_type="installation"
	else
		local version="dev"
		local install_type="development"
	fi

	echo "cco $version ($install_type)"
	echo "Installation: $CCO_INSTALLATION_DIR"
}

# Show comprehensive system information and status
show_info() {
	echo "cco - System Information & Status"
	echo "=================================="
	echo

	# Version info
	if [[ -d "$CCO_INSTALLATION_DIR/.git" ]]; then
		local version
		version=$(cd "$CCO_INSTALLATION_DIR" && git rev-parse --short HEAD 2>/dev/null || echo "unknown")
		local install_type="installation"
		local git_status
		git_status=$(cd "$CCO_INSTALLATION_DIR" && git status --porcelain 2>/dev/null)
	else
		local version="dev"
		local install_type="development"
		local git_status=""
	fi

	echo "📦 cco Information:"
	echo "  Version: $version ($install_type)"
	echo "  Location: $CCO_INSTALLATION_DIR"
	if [[ -n "$git_status" ]]; then
		echo "  Git Status: Modified (local changes present)"
	elif [[ "$install_type" == "installation" ]]; then
		echo "  Git Status: Clean"
	fi
	echo

	# Docker status
	echo "🐳 Docker Status:"
	if command -v docker &>/dev/null; then
		echo "  Docker CLI: ✓ Available"
		if docker info &>/dev/null; then
			local docker_version
			docker_version=$(docker version --format '{{.Server.Version}}' 2>/dev/null || echo "unknown")
			echo "  Docker Daemon: ✓ Running (v$docker_version)"

			# Check if our image exists
			if docker image inspect "$IMAGE_NAME" &>/dev/null; then
				local image_created
				image_created=$(docker image inspect "$IMAGE_NAME" --format '{{.Created}}' | cut -d'T' -f1)
				echo "  cco Image: ✓ Built ($image_created)"
			else
				echo "  cco Image: ✗ Not built (run with --rebuild)"
			fi
		else
			echo "  Docker Daemon: ✗ Not running"
		fi
	else
		echo "  Docker CLI: ✗ Not installed"
	fi
	echo

	# Claude Code status (informational only)
	echo "🤖 Claude Code Status:"
	if command -v claude &>/dev/null; then
		local claude_version
		claude_version=$(claude --version 2>/dev/null | head -1 || echo "unknown")
		echo "  Claude CLI: ✓ Available ($claude_version)"

		local claude_config_dir
		claude_config_dir=$(find_claude_config_dir)
		if [[ -d "$claude_config_dir" ]]; then
			echo "  Config Directory: ✓ Found ($claude_config_dir)"

			local auth_status="Optional / not configured"
			if command -v security &>/dev/null; then
				if security find-generic-password -s "Claude Code-credentials" -a "$USER" -w >/dev/null 2>&1; then
					auth_status="Configured (Keychain)"
				fi
			elif [[ -f "$claude_config_dir/.credentials.json" ]]; then
				auth_status="Configured (File)"
			fi
			echo "  Authentication: $auth_status"
		else
			echo "  Config Directory: Optional / not found"
			echo "  Authentication: Optional / not configured"
		fi
	else
		echo "  Claude CLI: Optional / not installed"
		echo "  Authentication: Optional / unavailable"
	fi
	echo

	# System info
	echo "💻 System Information:"
	echo "  OS: $(uname -s) $(uname -r)"
	echo "  Architecture: $(uname -m)"
	echo "  User: $(whoami)"
	echo "  UID/GID: $(id -u):$(id -g)"
	echo

	# Overall status
	echo "🎯 Overall Status:"
	local ready=true
	local issues=()

	if ! command -v docker &>/dev/null; then
		ready=false
		issues+=("Docker not installed")
	elif ! docker info &>/dev/null; then
		ready=false
		issues+=("Docker daemon not running")
	fi


	if [[ "$ready" = true ]]; then
		echo "  Status: ✓ Ready to use cco"
	else
		echo "  Status: ✗ Issues found"
		echo "  Issues:"
		for issue in "${issues[@]}"; do
			echo "    - $issue"
		done
	fi
}

# Run with native sandbox backend
run_native_sandbox() {
	local claude_config_dir
	claude_config_dir=$(find_claude_config_dir)
	local current_dir="$PWD"
	local project_claude_dir="$current_dir/.claude"

	log "Starting cco with native sandbox..."

	# Check if sandbox script exists
	local sandbox_script="$CCO_INSTALLATION_DIR/sandbox"
	if [[ ! -x "$sandbox_script" ]]; then
		error "Sandbox script not found or not executable: $sandbox_script"
		error "Falling back to Docker backend"
		SANDBOX_BACKEND="docker"
		check_docker_dependencies
		run_container
		return
	fi

	# Prepare sandbox access rules
	local sandbox_rules=()

	# Always allow writes to current project directory
	sandbox_rules+=("--write" "$current_dir")

	# Add any additional directories specified with --add-dir
	for dir in "${additional_dirs[@]}"; do
		if [[ -d "$dir" ]]; then
			sandbox_rules+=("--write" "$dir")
			log "Adding additional directory: $dir"
		fi
	done

	# Allow read-write access to the entire ~/.claude directory
	# This is needed for state files, MCP configs, session data, etc.
	# Even if config is in ~/.config/claude, Claude may need to write to ~/.claude
	if [[ ! -d "$HOME/.claude" ]]; then
		mkdir -p "$HOME/.claude"
	fi
	sandbox_rules+=("--write" "$HOME/.claude")

	# Also allow the detected config directory if it's different from ~/.claude
	if [[ "$claude_config_dir" != "$HOME/.claude" ]]; then
		sandbox_rules+=("--write" "$claude_config_dir")
	fi

	# Allow access to main .claude.json file (Claude needs to write to this)
	# This is a specific file in the home directory, NOT inside ~/.claude/
	# Create it if it doesn't exist so the sandbox can whitelist it
	if [[ ! -f "$HOME/.claude.json" ]]; then
		echo "{}" >"$HOME/.claude.json"
	fi
	sandbox_rules+=("--write" "$HOME/.claude.json")

	# Allow access to .claude.json.lock directory used by Claude's atomic-write
	# library (steno/write-file-atomic). Without this, mkdir fails with EROFS
	# in the bwrap sandbox since $HOME is read-only. See #23.
	if [[ ! -d "$HOME/.claude.json.lock" ]]; then
		mkdir -p "$HOME/.claude.json.lock"
	fi
	sandbox_rules+=("--write" "$HOME/.claude.json.lock")

	# Allow writes to ~/.npm for MCP server operations (npm cache/logs)
	if [[ ! -d "$HOME/.npm" ]]; then
		mkdir -p "$HOME/.npm"
	fi
	sandbox_rules+=("--write" "$HOME/.npm")

	# Allow writes to project-specific .claude directory
	if [[ -d "$project_claude_dir" ]]; then
		sandbox_rules+=("--write" "$project_claude_dir")
	fi

	# Allow writes to temp directory for credential syncing
	sandbox_rules+=("--write" "/tmp")

	# Apply read-only and deny rules from CLI
	for ro_path in "${additional_ro_paths[@]}"; do
		sandbox_rules+=("--read-only" "$ro_path")
		log "Adding read-only path: $ro_path"
	done

	for blocked_path in "${deny_paths[@]}"; do
		sandbox_rules+=("--deny" "$blocked_path")
		log "Denying path inside sandbox: $blocked_path"
	done

	# On macOS, Claude needs to access the Keychain directly
	# The sandbox-exec Seatbelt profile already allows default system operations
	# including Keychain access, so we don't need to pre-extract credentials

	# On Linux with bubblewrap, credentials are in files so no special handling needed

	# Build the command
	local cmd=("$sandbox_script")
	if [[ "$safe_mode" = true ]]; then
		cmd+=("--safe")
	fi
	if [[ "$allow_keychain" = true ]]; then
		cmd+=("--allow-keychain")
	fi
	cmd+=("${sandbox_rules[@]}")

	# Add separator and any extra backend args (from -- or CCO_SANDBOX_ARGS_FILE)
	# Format: sandbox [opts] -- [backend-args...] -- <command>
	# The sandbox script collects everything between the two -- markers as backend args
	if [[ ${#sandbox_extra_args[@]} -gt 0 ]]; then
		cmd+=("--" "${sandbox_extra_args[@]}" "--")
		log "Adding ${#sandbox_extra_args[@]} extra sandbox backend args"
	fi

	# Debug: Show the full sandbox command being executed
	if [[ "${CCO_DEBUG:-}" == "1" ]]; then
		log "DEBUG: Sandbox command: ${cmd[*]}"
	fi

	# Get command to use and split into array
	local cmd_str
	cmd_str=$(get_command)
	# Split command string into array (handles multi-word commands)
	read -ra cmd_array <<<"$cmd_str"

	# Add command
	if [[ "$shell_mode" = true ]]; then
		if [[ ${#claude_args[@]} -eq 0 ]]; then
			# Interactive shell mode - use user's preferred shell
			cmd+=("${SHELL:-bash}")
		else
			# Shell command mode
			cmd+=("bash" "-c" "${claude_args[*]}")
		fi
	else
		# Check if we're running a custom command (CCO_COMMAND or --command)
		if [[ -n "$command_flag" || -n "$CCO_COMMAND" ]]; then
			# Running custom command - pass arguments as-is, no Claude-specific flags
			if [[ ${#claude_args[@]} -eq 0 ]]; then
				cmd+=("${cmd_array[@]}")
			else
				cmd+=("${cmd_array[@]}" "${claude_args[@]}")
			fi
		else
			# Running Claude - use --dangerously-skip-permissions since we're in a sandbox
			if [[ ${#claude_args[@]} -eq 0 ]]; then
				cmd+=("${cmd_array[@]}" "--dangerously-skip-permissions")
			else
				cmd+=("${cmd_array[@]}" "--dangerously-skip-permissions" "${claude_args[@]}")
			fi
		fi
	fi

	# Load .env file first (matching Docker backend behavior)
	if [[ -f ".env" ]]; then
		while IFS= read -r line || [[ -n "$line" ]]; do
			# Skip empty lines and comments
			[[ -z "$line" || "$line" == \#* ]] && continue
			local env_key="${line%%=*}"
			local env_val="${line#*=}"
			export "${env_key}=${env_val}"
		done <".env"
	fi

	# Apply custom environment variables after .env so -e flags take precedence
	for custom_env in "${custom_env_vars[@]}"; do
		if [[ "$custom_env" == *"="* ]]; then
			local env_key="${custom_env%%=*}"
			local env_val="${custom_env#*=}"
			export "${env_key}=${env_val}"
		else
			# KEY-only format: pass through from host environment
			if [[ -n "${!custom_env}" ]]; then
				export "${custom_env}=${!custom_env}"
			fi
		fi
	done

	# Execute in sandbox with full environment
	exec "${cmd[@]}"
}

# Main run function (Docker backend)
run_container() {
	local host_uid
	host_uid=$(id -u)
	local host_gid
	host_gid=$(id -g)
	local current_dir="$PWD"

	log "Starting cco container..."

	# Remove existing container if it exists
	docker rm -f "$CONTAINER_NAME" &>/dev/null || true

	# Detect if we have a TTY
	local tty_flag=""
	if [[ -t 0 && -t 1 ]]; then
		tty_flag="-it"
	fi

	local docker_args=(
		--rm
		--init
		--name "$CONTAINER_NAME"
		--user "root"
		-e "HOST_UID=${host_uid}"
		-e "HOST_GID=${host_gid}"
		-v "$current_dir":"$current_dir"
		-w "$current_dir"
	)

	# Add docker mount with destination de-duplication.
	# If the target is already mounted read-only and a later mount requests
	# read-write access, upgrade the existing mount to read-write.
	mount_target_from_spec() {
		local spec="$1"
		local after_source="${spec#*:}"
		printf '%s\n' "${after_source%%:*}"
	}

	find_mount_spec_index() {
		local target="$1"
		local i=0
		while [[ $i -lt ${#docker_args[@]} ]]; do
			if [[ "${docker_args[$i]}" == "-v" ]]; then
				local spec="${docker_args[$((i + 1))]}"
				local existing_target
				existing_target=$(mount_target_from_spec "$spec")
				if [[ "$existing_target" == "$target" ]]; then
					echo "$((i + 1))"
					return 0
				fi
				((i += 2))
			else
				((i += 1))
			fi
		done
		return 1
	}

	add_mount_arg() {
		local source="$1"
		local target="$2"
		local mode="${3:-rw}"
		local mount_spec="$source:$target"
		if [[ "$mode" == "ro" ]]; then
			mount_spec="$mount_spec:ro"
		fi

		local existing_index
		if existing_index=$(find_mount_spec_index "$target"); then
			local existing_spec="${docker_args[$existing_index]}"
			local existing_mode="rw"
			if [[ "$existing_spec" == *":ro" ]]; then
				existing_mode="ro"
			fi

			if [[ "$mode" == "rw" && "$existing_mode" == "ro" ]]; then
				docker_args[existing_index]="$source:$target"
				warn "Upgrading duplicate mount to read-write for $target"
				return 0
			fi

			if [[ "$existing_spec" == "$mount_spec" ]]; then
				warn "Skipping duplicate mount for $target"
			else
				warn "Skipping conflicting mount for $target (keeping existing mount)"
			fi
			return 0
		fi

		docker_args+=(-v "$mount_spec")
	}

	# Determine the target user's home directory in container
	local container_home="/home/hostuser"

	# Determine Codex config directory mapping for Docker codex-mode sessions.
	# This ensures Codex auth/state resolves to the mounted directory even when
	# commands run with a different HOME (for example root inside container).
	local host_codex_home="${CODEX_HOME:-$HOME/.codex}"
	local resolved_host_codex_home
	resolved_host_codex_home=$(resolve_path "$host_codex_home")
	local container_codex_home="$resolved_host_codex_home"
	if [[ "$resolved_host_codex_home" == "$HOME"/* ]]; then
		local codex_relative="${resolved_host_codex_home#"$HOME"/}"
		container_codex_home="$container_home/$codex_relative"
	fi

	# Mount any additional directories specified with --add-dir
	# Remap $HOME-relative paths to $container_home inside the container
	# so agents can find their config dirs (e.g. ~/.codex → /home/hostuser/.codex)
	for dir in "${additional_dirs[@]}"; do
		if [[ -d "$dir" ]]; then
			if [[ -n "$git_worktree_common_dir" && "$dir" == "$git_worktree_common_dir" ]]; then
				add_mount_arg "$dir" "$dir"
				log "Mounting additional directory: $dir"
			elif [[ "$dir" == "$HOME"/* ]]; then
				local relative="${dir#"$HOME"/}"
				local container_dir="$container_home/$relative"
				add_mount_arg "$dir" "$container_dir"
				log "Mounting additional directory: $dir → $container_dir"
			else
				add_mount_arg "$dir" "$dir"
				log "Mounting additional directory: $dir"
			fi
		fi
	done

	# Track temporary overlays for deny paths
	local docker_cleanup_paths=()
	cleanup_docker_overlays() {
		for p in "${docker_cleanup_paths[@]}"; do
			if [[ -n "$p" && -e "$p" ]]; then
				rm -rf "$p"
			fi
		done
	}

	# In codex mode, mount a PATH shim so nested `codex` calls run with
	# bypass mode inside cco's outer sandbox.
	if [[ "$codex_mode" == true ]]; then
		local codex_shim_dir
		codex_shim_dir=$(create_codex_mode_shim_dir)
		docker_cleanup_paths+=("$codex_shim_dir")
		add_mount_arg "$codex_shim_dir" "$codex_shim_dir" "ro"
		docker_args+=(-e "CCO_PREPEND_PATH=$codex_shim_dir")
		log "Enabled codex-mode PATH shim for nested codex invocations"
	fi

	# Apply read-only mounts
	for ro_path in "${additional_ro_paths[@]}"; do
		if [[ -d "$ro_path" ]]; then
			add_mount_arg "$ro_path" "$ro_path" "ro"
		elif [[ -f "$ro_path" ]]; then
			add_mount_arg "$ro_path" "$ro_path" "ro"
		else
			warn "Skipping read-only mount (path disappeared): $ro_path"
		fi
		log "Mounting read-only path: $ro_path"
	done

	# Apply deny overlays by mounting empty temp locations
	for blocked_path in "${deny_paths[@]}"; do
		if [[ -d "$blocked_path" ]]; then
			tmp_overlay=$(mktemp -d)
			docker_cleanup_paths+=("$tmp_overlay")
			add_mount_arg "$tmp_overlay" "$blocked_path" "ro"
		elif [[ -f "$blocked_path" ]]; then
			tmp_overlay=$(mktemp)
			touch "$tmp_overlay"
			docker_cleanup_paths+=("$tmp_overlay")
			add_mount_arg "$tmp_overlay" "$blocked_path" "ro"
		else
			warn "Skipping deny overlay (path disappeared): $blocked_path"
			continue
		fi
		log "Denying path inside container: $blocked_path"
	done

	# Add TTY flags if available
	if [[ -n "$tty_flag" ]]; then
		docker_args+=("$tty_flag")
	fi

	# Detect host timezone and set container timezone
	local host_timezone=""
	if [[ -f /etc/timezone ]]; then
		# Linux: Read from /etc/timezone
		host_timezone=$(cat /etc/timezone)
	elif [[ -L /etc/localtime ]]; then
		# Linux/macOS: Extract from /etc/localtime symlink
		host_timezone=$(readlink /etc/localtime | sed 's|.*/zoneinfo/||')
	elif command -v timedatectl &>/dev/null; then
		# systemd systems: Use timedatectl
		host_timezone=$(timedatectl show --property=Timezone --value 2>/dev/null)
	elif [[ -f /etc/localtime ]]; then
		# Fallback: Try to determine timezone from /etc/localtime
		# This is more complex and may not always work reliably
		host_timezone=$(find /usr/share/zoneinfo -type f -exec cmp -s {} /etc/localtime \; -print | head -1 | sed 's|.*/zoneinfo/||')
	fi

	# Pass through relevant environment variables
	local env_vars=(
		# Anthropic / Claude Code
		"ANTHROPIC_API_KEY"
		"ANTHROPIC_BASE_URL"
		"CLAUDE_CONFIG_DIR"
		# OpenAI / Codex
		"OPENAI_API_KEY"
		# Google / Gemini
		"GEMINI_API_KEY"
		"GOOGLE_API_KEY"
		"GOOGLE_CLOUD_PROJECT"
		"GOOGLE_CLOUD_LOCATION"
		"GOOGLE_APPLICATION_CREDENTIALS"
		# Factory / Droid
		"FACTORY_API_KEY"
		# Agent config dir overrides
		"CODEX_HOME"
		"PI_CODING_AGENT_DIR"
		"GEMINI_SANDBOX"
		# Other LLM providers (used by pi, opencode, etc.)
		"GROQ_API_KEY"
		"MISTRAL_API_KEY"
		"XAI_API_KEY"
		"OPENROUTER_API_KEY"
		"CEREBRAS_API_KEY"
		"HUGGINGFACE_API_KEY"
		"AI_GATEWAY_API_KEY"
		# Chinese model providers
		"MOONSHOT_API_KEY"
		"KIMI_API_KEY"
		"ZHIPU_API_KEY"
		"ZAI_API_KEY"
		"MINIMAX_API_KEY"
		"DASHSCOPE_API_KEY"
		"QWEN_API_KEY"
		# Terminal / locale / proxy
		"XDG_CONFIG_HOME"
		"NO_COLOR"
		"TERM"
		"COLORTERM"
		"LANG"
		"LC_ALL"
		"HTTP_PROXY"
		"HTTPS_PROXY"
		"NO_PROXY"
		"GIT_AUTHOR_NAME"
		"GIT_AUTHOR_EMAIL"
		"GIT_COMMITTER_NAME"
		"GIT_COMMITTER_EMAIL"
	)

	for var in "${env_vars[@]}"; do
		if [[ -n "${!var}" ]]; then
			docker_args+=(-e "$var=${!var}")
		fi
	done

	# Set timezone in container
	if [[ -n "$host_timezone" ]]; then
		log "Setting container timezone to: $host_timezone"
		docker_args+=(-e "TZ=$host_timezone")
	elif [[ -n "$TZ" ]]; then
		# Use TZ environment variable if set
		docker_args+=(-e "TZ=$TZ")
	fi

	# Add custom environment variables from command line
	for custom_env in "${custom_env_vars[@]}"; do
		if [[ "$custom_env" == *"="* ]]; then
			# KEY=VALUE format
			docker_args+=(-e "$custom_env")
		else
			# KEY format - pass through from host environment
			if [[ -n "${!custom_env}" ]]; then
				docker_args+=(-e "$custom_env=${!custom_env}")
			fi
		fi
	done

	# Ensure Codex resolves auth/state from the mounted directory in codex-mode.
	if [[ "$codex_mode" == true ]]; then
		docker_args+=(-e "CODEX_HOME=$container_codex_home")
		log "Setting CODEX_HOME in container: $container_codex_home"
	fi

	# Load .env file if it exists
	[[ -f ".env" ]] && docker_args+=(--env-file .env)

	# Enable Claude Code background tasks when requested (can be enabled with --enable-background-tasks)
	if [[ "$enable_background_tasks" = true ]]; then
		docker_args+=(-e "ENABLE_BACKGROUND_TASKS=1")
	fi

	# Enable Docker access if requested
	if [[ "$docker_access" = true ]]; then
		# Check for Docker socket locations (Linux and macOS with Docker Desktop)
		if [[ -S "/var/run/docker.sock" ]]; then
			log "Enabling Docker access via /var/run/docker.sock"
			add_mount_arg "/var/run/docker.sock" "/var/run/docker.sock"
		elif [[ -S "$HOME/.docker/run/docker.sock" ]]; then
			log "Enabling Docker access via $HOME/.docker/run/docker.sock"
			add_mount_arg "$HOME/.docker/run/docker.sock" "/var/run/docker.sock"
		else
			warn "Docker socket not found - Docker access may not work"
			warn "Tried: /var/run/docker.sock, $HOME/.docker/run/docker.sock"
		fi
	fi

	# Configure container networking for MCP server access
	setup_container_networking() {
		local use_host_networking=false
		local networking_method=""

		# Check if Docker daemon supports host networking by looking for host network driver
		if [[ "$force_bridge_network" = true ]]; then
			networking_method="Docker bridge networking (forced via --force-docker-bridge-network)"
		elif docker network ls --format "{{.Driver}}" 2>/dev/null | grep -q "^host$"; then
			use_host_networking=true
			networking_method="Docker host networking"
		else
			networking_method="Docker bridge networking (host not available)"
		fi

		if [[ "$use_host_networking" = true ]]; then
			docker_args+=(--network=host)
			log "Using host networking for MCP server access ($networking_method)"
		else
			docker_args+=(--add-host=host.docker.internal:host-gateway)
			networking_method="host.docker.internal bridge"
			log "Using bridge networking ($networking_method)"

			# Warn about MCP server connectivity limitations
			if [[ -d "$HOME/.claude" && $(find "$HOME/.claude" -name "*.json" -exec grep -l "localhost\|127\.0\.0\.1" {} \; 2>/dev/null | wc -l) -gt 0 ]]; then
				warn "Detected Claude configs referencing localhost - MCP servers may not be accessible"
				warn "Consider upgrading to Docker Desktop 4.34+ or using OrbStack for full MCP server support"
				warn "Alternative: Reconfigure MCP servers to use host.docker.internal instead of localhost"
			fi
		fi
	}

	setup_container_networking

	# Set up Claude Code configuration in container
	local host_system_claude_dir
	host_system_claude_dir=$(find_claude_config_dir)
	local project_claude_dir="$current_dir/.claude"

	# container_home already set above (for additional_dirs remapping)

	# Let Claude Code auto-detect its config directory (don't override with CLAUDE_CONFIG_DIR)

	# Create temporary directory for credentials extraction
	local temp_creds_dir
	temp_creds_dir=$(mktemp -d)
	local original_creds_content=""
	local host_creds_file=""
	local startup_system_creds_content=""

	# Setup cleanup and credentials sync-back on exit
	if [[ "$allow_oauth_refresh" = true ]]; then
		trap 'sync_credentials_back "$temp_creds_dir" "$original_creds_content" "$host_creds_file" "$startup_system_creds_content" && rm -rf "$temp_creds_dir"; cleanup_docker_overlays' EXIT
	else
		trap 'rm -rf "$temp_creds_dir"; cleanup_docker_overlays' EXIT
	fi

	# Ensure ~/.claude directory exists and mount it (read-write for state updates)
	# Claude needs to write to this directory for session data, MCP configs, etc.
	if [[ ! -d "$HOME/.claude" ]]; then
		mkdir -p "$HOME/.claude"
	fi
	log "Mounting ~/.claude directory: $HOME/.claude → $container_home/.claude"
	add_mount_arg "$HOME/.claude" "$container_home/.claude"

	# If the detected config directory is different from ~/.claude, mount it too.
	# When Claude has never been run, this directory may not exist yet.
	if [[ "$host_system_claude_dir" != "$HOME/.claude" ]] && [[ -d "$host_system_claude_dir" ]]; then
		log "Also mounting config directory: $host_system_claude_dir → $container_home/.config/claude"
		# Create the parent directory in the mount command
		add_mount_arg "$host_system_claude_dir" "$container_home/.config/claude"
	fi

	# Extract fresh credentials from keychain for macOS
	if command -v security &>/dev/null; then
		local keychain_creds
		keychain_creds=$(security find-generic-password -s "Claude Code-credentials" -a "$USER" -w 2>/dev/null || echo "")
		if [[ -n "$keychain_creds" ]]; then
			echo "$keychain_creds" >"$temp_creds_dir/.credentials.json"
			chmod 600 "$temp_creds_dir/.credentials.json"

			# Store original content for sync-back detection if --allow-oauth-refresh enabled
			if [[ "$allow_oauth_refresh" = true ]]; then
				original_creds_content=$(cat "$temp_creds_dir/.credentials.json")
				startup_system_creds_content="$keychain_creds"
				host_creds_file="" # macOS uses Keychain, not file
			fi

			# Mount credentials with appropriate permissions based on --allow-oauth-refresh
			if [[ "$allow_oauth_refresh" = true ]]; then
				add_mount_arg "$temp_creds_dir/.credentials.json" "$container_home/.claude/.credentials.json"
				log "Mounting fresh credentials from macOS Keychain (read-write for OAuth refresh)"
			else
				add_mount_arg "$temp_creds_dir/.credentials.json" "$container_home/.claude/.credentials.json" "ro"
				log "Mounting fresh credentials from macOS Keychain (read-only)"
			fi
		fi
	elif [[ -f "$host_system_claude_dir/.credentials.json" ]]; then
		# Linux: Copy from existing credentials file
		cp "$host_system_claude_dir/.credentials.json" "$temp_creds_dir/.credentials.json"
		chmod 600 "$temp_creds_dir/.credentials.json"

		# Store original content for sync-back detection if --allow-oauth-refresh enabled
		if [[ "$allow_oauth_refresh" = true ]]; then
			original_creds_content=$(cat "$temp_creds_dir/.credentials.json")
			startup_system_creds_content=$(cat "$host_system_claude_dir/.credentials.json")
			host_creds_file="$host_system_claude_dir/.credentials.json"
		fi

		# Mount credentials with appropriate permissions based on --allow-oauth-refresh
		if [[ "$allow_oauth_refresh" = true ]]; then
			add_mount_arg "$temp_creds_dir/.credentials.json" "$container_home/.claude/.credentials.json"
			log "Mounting credentials file (read-write for OAuth refresh)"
		else
			add_mount_arg "$temp_creds_dir/.credentials.json" "$container_home/.claude/.credentials.json" "ro"
			log "Mounting credentials file (read-only)"
		fi
	fi

	# Mount main .claude.json from home directory (this is separate from .claude/)
	# Create it if it doesn't exist to ensure Claude can write to it
	if [[ ! -f "$HOME/.claude.json" ]]; then
		echo "{}" >"$HOME/.claude.json"
	fi
	log "Mounting main .claude.json from home directory"
	add_mount_arg "$HOME/.claude.json" "$container_home/.claude.json"

	# Mount project-specific .claude directory (read-write for project settings)
	if [[ -d "$project_claude_dir" ]]; then
		log "Mounting project Claude config from $project_claude_dir (read-write)"
		add_mount_arg "$project_claude_dir" "$project_claude_dir"
	fi

	# Bind mount common config files
	[[ -f "$HOME/.gitconfig" ]] && add_mount_arg "$HOME/.gitconfig" "$container_home/.gitconfig" "ro"
	[[ -d "$HOME/.ssh" ]] && add_mount_arg "$HOME/.ssh" "$container_home/.ssh" "ro"

	# Add any extra sandbox args (from -- or CCO_SANDBOX_ARGS_FILE)
	if [[ ${#sandbox_extra_args[@]} -gt 0 ]]; then
		log "Adding ${#sandbox_extra_args[@]} extra sandbox args"
		docker_args+=("${sandbox_extra_args[@]}")
	fi

	# Function to start background SIGWINCH monitor
	start_sigwinch_monitor() {
		local container_name="$1"

		# Background process to monitor and forward SIGWINCH signals to container
		(
			# Wait for container to initialize
			sleep 2

			# Set up signal handler to forward SIGWINCH to container processes
			# shellcheck disable=SC2064  # Intentional: expand container_name at definition time
			trap "docker exec '$container_name' pkill -SIGWINCH -u hostuser 2>/dev/null" WINCH

			# Keep monitor alive while container exists
			while docker ps --format '{{.Names}}' | grep -q "^$container_name\$" 2>/dev/null; do
				sleep 2
			done
		) &
	}

	# Run the container (entrypoint will handle user setup)
	if [[ "$shell_mode" = true ]]; then
		if [[ ${#claude_args[@]} -eq 0 ]]; then
			# Interactive shell mode - Docker image may not have user's $SHELL
			start_sigwinch_monitor "$CONTAINER_NAME"
			docker run "${docker_args[@]}" "$IMAGE_NAME" bash
		else
			# Shell command mode
			docker run "${docker_args[@]}" "$IMAGE_NAME" bash -c "${claude_args[*]}"
		fi
	else
		start_sigwinch_monitor "$CONTAINER_NAME"
		# Get command to use and split into array for Docker run too
		local cmd_str
		cmd_str=$(get_command)
		read -ra cmd_array <<<"$cmd_str"

		# Check if we're running a custom command (CCO_COMMAND or --command)
		if [[ -n "$command_flag" || -n "$CCO_COMMAND" ]]; then
			# Running custom command - pass arguments as-is, no Claude-specific flags
			docker run "${docker_args[@]}" "$IMAGE_NAME" "${cmd_array[@]}" "${claude_args[@]}"
		else
			# Running Claude - use --dangerously-skip-permissions
			docker run "${docker_args[@]}" "$IMAGE_NAME" "${cmd_array[@]}" --dangerously-skip-permissions "${claude_args[@]}"
		fi
	fi
	local run_status=$?
	cleanup_docker_overlays
	trap - EXIT
	return $run_status
}

# Backup Claude Code credentials to a safe location
backup_credentials() {
	local backup_dir="$HOME/.cco-backups"
	local timestamp
	timestamp=$(date +"%Y%m%d_%H%M%S")
	local backup_file="$backup_dir/claude-credentials.$timestamp.json"

	# Create backup directory if it doesn't exist
	mkdir -p "$backup_dir"

	log "Backing up Claude Code credentials..."

	if command -v security &>/dev/null; then
		# macOS: Extract from Keychain
		local keychain_creds
		keychain_creds=$(security find-generic-password -s "Claude Code-credentials" -a "$USER" -w 2>/dev/null || echo "")
		if [[ -n "$keychain_creds" ]]; then
			echo "$keychain_creds" >"$backup_file"
			chmod 600 "$backup_file"
			log "Successfully backed up Keychain credentials to: $backup_file"
			echo "To restore: ./cco restore-creds \"$backup_file\""
		else
			error "No Claude Code credentials found in macOS Keychain"
			exit 1
		fi
	else
		# Linux: Copy from credentials file
		local claude_config_dir
		claude_config_dir=$(find_claude_config_dir)
		local creds_file="$claude_config_dir/.credentials.json"

		if [[ -f "$creds_file" ]]; then
			cp "$creds_file" "$backup_file"
			chmod 600 "$backup_file"
			log "Successfully backed up credentials file to: $backup_file"
			echo "To restore: ./cco restore-creds \"$backup_file\""
		else
			error "No Claude Code credentials file found at: $creds_file"
			exit 1
		fi
	fi
}

# Restore Claude Code credentials from a backup
restore_credentials() {
	local backup_file="$1"
	local backup_dir="$HOME/.cco-backups"

	if [[ -z "$backup_file" ]]; then
		# Auto-select most recent backup
		if [[ ! -d "$backup_dir" ]]; then
			error "No backup directory found at: $backup_dir"
			echo "Run './cco backup-creds' first to create a backup"
			exit 1
		fi

		# Find the most recent backup file
		backup_file=$(find "$backup_dir" -name "claude-credentials.*.json" -not -name "*.pre-restore.*" -type f -print0 2>/dev/null | xargs -0 ls -t | head -1)

		if [[ -z "$backup_file" ]]; then
			error "No backup files found in: $backup_dir"
			echo "Run './cco backup-creds' first to create a backup"
			exit 1
		fi

		# Confirm with user
		echo "Most recent backup found: $(basename "$backup_file")"
		echo "Created: $(date -r "$backup_file" 2>/dev/null || stat -c %y "$backup_file" 2>/dev/null || echo "unknown")"
		echo
		read -p "Restore this backup? [y/N]: " -r
		if [[ ! $REPLY =~ ^[Yy]$ ]]; then
			echo "Restore cancelled"
			exit 0
		fi
	fi

	if [[ ! -f "$backup_file" ]]; then
		error "Backup file not found: $backup_file"
		exit 1
	fi

	log "Restoring Claude Code credentials from: $backup_file"

	# Create a backup of current credentials before restoring
	local current_backup_timestamp
	current_backup_timestamp=$(date +"%Y%m%d_%H%M%S")

	if command -v security &>/dev/null; then
		# macOS: Backup current and restore to Keychain
		log "Creating backup of current Keychain credentials..."
		local current_creds
		current_creds=$(security find-generic-password -s "Claude Code-credentials" -a "$USER" -w 2>/dev/null || echo "")
		if [[ -n "$current_creds" ]]; then
			local current_backup_dir="$HOME/.cco-backups"
			mkdir -p "$current_backup_dir"
			echo "$current_creds" >"$current_backup_dir/claude-credentials.pre-restore.$current_backup_timestamp.json"
			log "Current credentials backed up to: $current_backup_dir/claude-credentials.pre-restore.$current_backup_timestamp.json"
		fi

		# Restore from backup file
		local restore_creds
		restore_creds=$(cat "$backup_file")
		if security add-generic-password -U -s "Claude Code-credentials" -a "$USER" -w "$restore_creds" >/dev/null 2>&1; then
			log "Successfully restored credentials to macOS Keychain"
		else
			error "Failed to restore credentials to macOS Keychain"
			exit 1
		fi
	else
		# Linux: Backup current and restore to file
		local claude_config_dir
		claude_config_dir=$(find_claude_config_dir)
		local creds_file="$claude_config_dir/.credentials.json"

		# Backup current credentials if they exist
		if [[ -f "$creds_file" ]]; then
			local current_backup_file="${creds_file}.pre-restore.$current_backup_timestamp"
			cp "$creds_file" "$current_backup_file"
			log "Current credentials backed up to: $current_backup_file"
		fi

		# Restore from backup
		if cp "$backup_file" "$creds_file"; then
			chmod 600 "$creds_file"
			log "Successfully restored credentials to: $creds_file"
		else
			error "Failed to restore credentials to: $creds_file"
			exit 1
		fi
	fi
}

# Initialize variables
claude_args=()
additional_dirs=()
additional_ro_paths=()
deny_paths=()
custom_env_vars=()
custom_packages=()
sandbox_extra_args=()
git_worktree_common_dir=""
docker_access=false
allow_oauth_refresh=false
allow_keychain=false
enable_background_tasks=false
rebuild_image=false
pull_image=false
shell_mode=false
safe_mode=false
force_bridge_network=false
allow_external_git_dir=false
enable_git_worktree_common_dir=true
claude_command_flag=""
command_flag=""
codex_mode=false

if [[ "${CCO_ALLOW_EXTERNAL_GIT_DIR:-}" == "1" ]]; then
	allow_external_git_dir=true
fi

# Load sandbox args from file if CCO_SANDBOX_ARGS_FILE is set
if [[ -n "${CCO_SANDBOX_ARGS_FILE:-}" ]]; then
	if [[ -f "$CCO_SANDBOX_ARGS_FILE" ]]; then
		while IFS= read -r line || [[ -n "$line" ]]; do
			# Skip empty lines and comments
			[[ -z "$line" || "$line" == \#* ]] && continue
			sandbox_extra_args+=("$line")
		done <"$CCO_SANDBOX_ARGS_FILE"
		log "Loaded ${#sandbox_extra_args[@]} sandbox args from $CCO_SANDBOX_ARGS_FILE"
	else
		warn "CCO_SANDBOX_ARGS_FILE set but file not found: $CCO_SANDBOX_ARGS_FILE"
	fi
fi

# Normalize --flag=value into --flag value for consistent parsing
# Only normalize args before --, passthrough args are left as-is
normalized_args=()
found_separator=false
for arg in "$@"; do
	if [[ "$arg" == "--" ]]; then
		found_separator=true
		normalized_args+=("$arg")
	elif [[ "$found_separator" == false && "$arg" == --*=* ]]; then
		normalized_args+=("${arg%%=*}" "${arg#*=}")
	else
		normalized_args+=("$arg")
	fi
done
set -- "${normalized_args[@]}"

# First pass: Extract cco-specific flags and collect remaining args
# This ensures --add-dir and other cco flags are parsed before subcommands
remaining_args=()
while [[ $# -gt 0 ]]; do
	case $1 in
	--backend)
		if [[ $# -lt 2 ]]; then
			error "--backend requires an argument (auto, native, docker)"
			exit 1
		fi
		SANDBOX_BACKEND="$2"
		shift 2
		;;
	--rebuild)
		rebuild_image=true
		shift
		;;
	--pull)
		pull_image=true
		shift
		;;
	--docker-socket)
		docker_access=true
		shift
		;;
	--force-docker-bridge-network)
		force_bridge_network=true
		shift
		;;
	--allow-oauth-refresh)
		allow_oauth_refresh=true
		shift
		;;
	--allow-keychain)
		allow_keychain=true
		shift
		;;
	--enable-background-tasks)
		enable_background_tasks=true
		shift
		;;
	--safe)
		safe_mode=true
		shift
		;;
	--codex-mode)
		configure_codex_mode_paths
		shift
		;;
	--allow-external-git-dir)
		allow_external_git_dir=true
		shift
		;;
	--disable-git-worktree-common-dir)
		enable_git_worktree_common_dir=false
		shift
		;;
	--claude-command)
		if [[ $# -lt 2 ]]; then
			error "--claude-command requires an argument (command to use instead of 'claude')"
			exit 1
		fi
		claude_command_flag="$2"
		shift 2
		;;
	--command)
		if [[ $# -lt 2 ]]; then
			error "--command requires an argument (command to run instead of claude)"
			exit 1
		fi
		command_flag="$2"
		shift 2
		;;
	--env | -e)
		if [[ $# -lt 2 ]]; then
			error "--env requires an argument (KEY=VALUE or KEY)"
			exit 1
		fi
		custom_env_vars+=("$2")
		shift 2
		;;
	--packages | -p)
		if [[ $# -lt 2 ]]; then
			error "--packages requires an argument (package1,package2,...)"
			exit 1
		fi
		IFS=',' read -ra ADDR <<<"$2"
		for pkg in "${ADDR[@]}"; do
			custom_packages+=("$pkg")
		done
		shift 2
		;;
	--allow-readonly | --allow-readonly=*)
		if [[ "$1" == *"="* ]]; then
			path="${1#*=}"
			resolved=$(resolve_path "$path")
			add_ro_path "$resolved"
			shift
		else
			shift
			if [[ $# -eq 0 ]]; then
				error "--allow-readonly requires at least one path"
				exit 1
			fi
			while [[ $# -gt 0 ]] && [[ ! "$1" =~ ^- ]]; do
				resolved=$(resolve_path "$1")
				add_ro_path "$resolved"
				shift
			done
		fi
		;;
	--deny-path | --deny-path=*)
		if [[ "$1" == *"="* ]]; then
			path="${1#*=}"
			resolved=$(resolve_path "$path")
			add_deny_path "$resolved"
			shift
		else
			shift
			if [[ $# -eq 0 ]]; then
				error "--deny-path requires at least one path"
				exit 1
			fi
			while [[ $# -gt 0 ]] && [[ ! "$1" =~ ^- ]]; do
				resolved=$(resolve_path "$1")
				add_deny_path "$resolved"
				shift
			done
		fi
		;;
	--add-dir | --add-dir=*)
		# Handle --add-dir for both notations - this is a cco flag, not passed to command
		if [[ "$1" == *"="* ]]; then
			# --add-dir=<dir[:mode]> notation
			handle_add_dir_entry "${1#*=}"
			shift
		else
			# --add-dir <dir> notation
			shift
			# Collect directories until next flag or known subcommand
			while [[ $# -gt 0 ]] && [[ ! "$1" =~ ^- ]]; do
				# Stop if we hit a known subcommand
				case "$1" in
				shell | codex | droid | opencode | pi | gemini | self-update | cleanup | info | backup-creds | restore-creds | pull | rebuild)
					# This is a subcommand, not a directory
					break
					;;
				*)
					handle_add_dir_entry "$1"
					shift
					;;
				esac
			done
		fi
		;;
	--)
		# Everything after -- goes to the sandbox backend (docker/bwrap/sandbox-exec)
		shift
		sandbox_extra_args+=("$@")
		break
		;;
	*)
		# Not a cco flag, keep for subcommand/Claude processing
		remaining_args+=("$1")
		shift
		;;
	esac
done

# Now handle subcommands with remaining args
set -- "${remaining_args[@]}"
if [[ $# -gt 0 ]]; then
	case $1 in
